{
  "expo": {
    "name": "Birikim Yap",
    "slug": "birikim-yap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Birikim Yap sesle harcama eklemek için mikrofonu kullanır.",
          "speechRecognitionPermission": "Birikim Yap söylediklerini harcama kaydına dönüştürmek için konuşma tanımayı kullanır.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ]
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDFBF6"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Birikim Yap söylediklerini harcama kaydına dönüştürmek için konuşma tanımayı kullanır.",
        "NSMicrophoneUsageDescription": "Birikim Yap sesle harcama eklemek için mikrofonu kullanır."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FDFBF6"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.thewalkingman.birikimyap"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
